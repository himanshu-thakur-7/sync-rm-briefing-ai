# ─── Ringg AI (hackathon voice platform) ─────────────────────────────────────
RINGG_API_KEY=
RINGG_BASE_URL=https://prod-api.ringg.ai/ca/api/v0
RINGG_AGENT_ID=
RINGG_FROM_NUMBER_ID=

# ─── OpenAI (briefing generation + voice command parsing) ────────────────────
OPENAI_API_KEY=

# ─── CRM Adapter (default = sandbox demo; switch after connecting a real CRM) ─
# Options: mock | hubspot | salesforce | zoho | dynamics | freshworks | leadsquared
CRM_ADAPTER=mock

# ─── HubSpot OAuth app credentials ───────────────────────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
# Legacy token (optional; use if you have a private app instead of OAuth)
HUBSPOT_API_KEY=

# ─── Salesforce OAuth app credentials ────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Legacy session token (optional)
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=

# ─── Zoho CRM OAuth ──────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.in

# ─── Microsoft Dynamics 365 OAuth (via Azure AD) ─────────────────────────────
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_TENANT_ID=
DYNAMICS_INSTANCE_URL=

# ─── Freshworks CRM (API key, no OAuth) ──────────────────────────────────────
FRESHWORKS_SUBDOMAIN=
FRESHWORKS_API_KEY=

# ─── LeadSquared CRM (API key, no OAuth) ─────────────────────────────────────
LEADSQUARED_ACCESS_KEY=
LEADSQUARED_SECRET_KEY=
LEADSQUARED_REGION=api-in21

# ─── Platform secrets ────────────────────────────────────────────────────────
# SYNC_SECRET_KEY: Fernet key for OAuth token encryption.
# Generated automatically on first boot if blank (written to .secret.key).
# Set this explicitly in production.
SECRET_KEY=

WEBHOOK_SECRET=sync-webhook-secret

# ─── URLs ─────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# OAuth callback base — set to ngrok URL in dev, deployed URL in prod.
# Leave blank to use BACKEND_URL.
OAUTH_REDIRECT_BASE=

# Extra CORS origin (e.g. your ngrok tunnel URL during development)
CORS_EXTRA_ORIGIN=

# ─── Dashboard defaults ───────────────────────────────────────────────────────
DEMO_RM_PHONE=+919876543210
DEMO_RM_NAME=Himanshu
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_DEMO_RM_PHONE=+919876543210
VITE_DEMO_RM_NAME=Himanshu

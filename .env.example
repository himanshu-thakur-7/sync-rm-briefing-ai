# SYNC — environment template. Copy to .env and fill what you use.
# Everything is optional: missing keys degrade to simulations/fallbacks.

# ── Core ──────────────────────────────────────────────────────────────
SECRET_KEY=                       # Fernet key for OAuth token encryption (auto-generated on Render)
WEBHOOK_SECRET=
CRM_ADAPTER=pipedrive             # default CRM: mock | pipedrive | hubspot | …
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000 # public URL in prod — Twilio TwiML + Ringg webhooks resolve against it
LOCAL_TIMEZONE=Asia/Kolkata       # spoken times ("Thursday 4 PM") interpreted here

# ── Ringg AI (voice core) ─────────────────────────────────────────────
RINGG_API_KEY=                    # UUID-format key — calls + Parrot STT
RINGG_AGENT_ID=                   # SYNC briefing agent
RINGG_FROM_NUMBER_ID=             # outbound DID id
RINGG_OUTREACH_AGENT_ID=          # client-facing save-call agent
RINGG_MORNING_BRIEF_AGENT_ID=     # conversational standup agent
RINGG_CONCIERGE_AGENT_ID=         # inbound concierge agent
RINGG_INBOUND_NUMBER=             # display number for the Concierge widget
RINGG_STT_API_KEY=                # Parrot STT key (falls back to RINGG_API_KEY)
RINGG_STT_LANGUAGE=en             # en | hi

# ── OpenAI (text intelligence only) ───────────────────────────────────
OPENAI_API_KEY=                   # briefings, post-call analysis, GPT coaching nudges

# ── Twilio (Coached Calls bridge) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=               # E.164

# ── ElevenLabs (simulation theater voices) ────────────────────────────
ELEVENLABS_API_KEY=               # free tier OK — audio is pre-generated + disk-cached
ELEVENLABS_VOICE_RM=              # optional override (default "Eric")
ELEVENLABS_VOICE_CLIENT=          # optional override (default "Chris")

# ── Pipedrive (demo CRM) ──────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=         # e.g. "sync2" → sync2.pipedrive.com

# ── Demo wiring ───────────────────────────────────────────────────────
DEMO_CLIENT_PHONE=+91XXXXXXXXXX   # the phone playing the "client"
DEMO_RM_PHONE=+91XXXXXXXXXX       # the RM's phone
DEMO_COMPANY_NAME=Acme

# ── Other CRM providers (optional OAuth apps) ─────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_TENANT_ID=
FRESHWORKS_SUBDOMAIN=
FRESHWORKS_API_KEY=
LEADSQUARED_ACCESS_KEY=
LEADSQUARED_SECRET_KEY=

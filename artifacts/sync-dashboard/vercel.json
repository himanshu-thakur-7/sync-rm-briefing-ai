{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/sync-dashboard build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://sync-backend-u9rv.onrender.com/api/:path*" },
    { "source": "/v1/:path*", "destination": "https://sync-backend-u9rv.onrender.com/v1/:path*" },
    { "source": "/ws/:path*", "destination": "https://sync-backend-u9rv.onrender.com/ws/:path*" },
    { "source": "/((?!api/|v1/|ws/).*)", "destination": "/index.html" }
  ]
}
